# 正式运营环境变量（阿里云 Docker）。内测请用 .env.internal.example
#   cp .env.production.example .env
# docker compose 会自动读取同目录的 .env 做变量替换。

# --- 数据库（docker-compose 内置 PostgreSQL）---
POSTGRES_USER=lezyou
POSTGRES_DB=lezyou
# 必填：数据库密码（请改成强密码）
POSTGRES_PASSWORD=change-this-strong-password

# 若改用阿里云 RDS PostgreSQL（不使用内置 db 服务），
# 直接在 app 服务里设置 DATABASE_URL，并移除 docker-compose 的 db 服务即可：
# DATABASE_URL=postgresql://USER:PASSWORD@rds-host:5432/lezyou?schema=public

# --- 会话密钥（必填）---
# 生成：openssl rand -base64 48
AUTH_SECRET=change-to-a-long-random-secret

# --- Cookie 安全标记 ---
# 已配 HTTPS：true；仅用 http://公网IP 临时测试：false（否则无法登录）
COOKIE_SECURE=true

# --- 验证码 / 短信 ---
# 上线初期可保持 on（验证码固定为下方 DEMO_VERIFICATION_CODE，便于试用）
# 正式运营请设为 off，并在 src/lib/server/verification.ts 接入阿里云短信
DEMO_CODE_ENABLED=off
DEMO_VERIFICATION_CODE=888888
NEXT_PUBLIC_DEMO_MODE=off

# --- 阿里云短信（DEMO_CODE_ENABLED=off 时必填 SMS_PROVIDER）---
# SMS_PROVIDER=aliyun
# SMS_ACCESS_KEY_ID=
# SMS_ACCESS_KEY_SECRET=
# SMS_SIGN_NAME=
# SMS_TEMPLATE_CODE=

# --- 定时任务（订单超时：10 天验收 / 30 天结案）---
# 建议 crontab 每小时：./scripts/cron-order-timeouts.sh
# CRON_SECRET=

# --- 构建参数（docker compose build 时读取，写入前端包）---
# NEXT_PUBLIC_DEMO_MODE=off

# --- 支付 ---
# 渠道：sandbox（默认）| wechat | alipay
PAYMENT_PROVIDER=sandbox
# 站点对外根地址，必须是支付平台能回调到的公网地址（用于 notify_url）
PUBLIC_BASE_URL=https://your-domain.com

# 微信支付 V3（Native 扫码）
# WECHAT_PAY_APPID=
# WECHAT_PAY_MCH_ID=
# WECHAT_PAY_SERIAL_NO=
# WECHAT_PAY_PRIVATE_KEY=
# WECHAT_PAY_APIV3_KEY=
# WECHAT_PAY_PLATFORM_PUBLIC_KEY=

# 支付宝（当面付 precreate 扫码）
# ALIPAY_APP_ID=
# ALIPAY_PRIVATE_KEY=
# ALIPAY_PUBLIC_KEY=
# ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
