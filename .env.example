# 数据库连接串
# 本地开发（SQLite）：
DATABASE_URL="file:./dev.db"
# 生产（PostgreSQL 示例，需同时把 prisma/schema.prisma 的 provider 改为 postgresql）：
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/lezyou?schema=public"

# 会话签名密钥（生产必须替换为随机长字符串，例如 openssl rand -base64 48）
AUTH_SECRET="please-change-to-a-long-random-secret"

# 演示验证码开关：生产环境请设为 off，并接入真实短信服务
DEMO_VERIFICATION_CODE="888888"
DEMO_CODE_ENABLED="on"
# 演示身份切换器（右下角 FAB）：生产环境设为 off；内测保持 on
NEXT_PUBLIC_DEMO_MODE="on"

# 内测服务器部署请复制 .env.internal.example → .env（见 README「内测部署」）

# 短信服务（接入真实短信时填写，示例为阿里云）
# SMS_PROVIDER="aliyun"
# SMS_ACCESS_KEY_ID=""
# SMS_ACCESS_KEY_SECRET=""
# SMS_SIGN_NAME=""
# SMS_TEMPLATE_CODE=""

# 支付渠道：sandbox（默认，免凭证跑通流程）| wechat | alipay
PAYMENT_PROVIDER="sandbox"
# 沙箱是否「创建即支付成功」（保留一键体验）；设 false 则需扫码/手动确认
DEMO_PAYMENT_AUTOCONFIRM_NOTE="环境变量名为 PAYMENT_SANDBOX_AUTOCONFIRM，默认 true"
# PAYMENT_SANDBOX_AUTOCONFIRM="true"
# 站点对外根地址（用于拼接支付异步回调 notify_url）
PUBLIC_BASE_URL="http://localhost:3000"

# 定时任务密钥（POST /api/cron/order-timeouts，Header: Authorization: Bearer <CRON_SECRET>）
# CRON_SECRET=""

# 微信支付 V3（Native 扫码）。拿到商户资质后填写：
# WECHAT_PAY_APPID=""
# WECHAT_PAY_MCH_ID=""
# WECHAT_PAY_SERIAL_NO=""
# WECHAT_PAY_PRIVATE_KEY=""          # 商户 API 私钥 PEM（换行用 \n 转义）
# WECHAT_PAY_APIV3_KEY=""            # APIv3 密钥（回调解密）
# WECHAT_PAY_PLATFORM_PUBLIC_KEY=""  # 微信支付平台公钥 PEM（回调验签，可选）

# 支付宝（当面付 precreate 扫码）：
# ALIPAY_APP_ID=""
# ALIPAY_PRIVATE_KEY=""              # 应用私钥 PEM（换行用 \n 转义）
# ALIPAY_PUBLIC_KEY=""               # 支付宝公钥 PEM（回调验签）
# ALIPAY_GATEWAY="https://openapi.alipay.com/gateway.do"
