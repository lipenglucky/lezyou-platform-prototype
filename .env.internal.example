# 内测环境变量（阿里云 ECS · Docker Compose）
# 用法：cp .env.internal.example .env  →  改密码/域名  →  docker compose up -d --build
#
# 内测特性：固定验证码 888888、沙箱支付、右下角身份切换器、空库自动播种演示数据。

# --- 数据库 ---
POSTGRES_USER=lezyou
POSTGRES_DB=lezyou
POSTGRES_PASSWORD=请改成强密码

# --- 会话（必填）---
# openssl rand -base64 48
AUTH_SECRET=请改成随机长字符串

# --- 访问方式 ---
# 已配 HTTPS + 域名：true
# 仅用 http://公网IP:3000 内测（配合 docker-compose.internal.yml）：false
COOKIE_SECURE=false

# --- 内测：演示验证码 + 身份切换器 ---
DEMO_CODE_ENABLED=on
DEMO_VERIFICATION_CODE=888888
# 构建镜像时写入前端（docker compose build 会读取此项）
NEXT_PUBLIC_DEMO_MODE=on

# --- 沙箱支付（内测默认，无需商户号）---
PAYMENT_PROVIDER=sandbox
# true=付款意图创建即成功；false=需点「确认支付」按钮
PAYMENT_SANDBOX_AUTOCONFIRM=true
# 改成你的访问地址（IP 或域名），支付回调与转发链接会用到
PUBLIC_BASE_URL=http://你的公网IP:3000

# --- 订单超时定时任务（建议配置）---
# 服务器 crontab 每小时执行 scripts/cron-order-timeouts.sh
CRON_SECRET=请改成随机字符串
